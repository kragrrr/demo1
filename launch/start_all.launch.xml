<launch>
    <set_parameter name="use_sim_time" value="true" />

    <!-- SLAM -->
    <include file="$(find-pkg-share slam_toolbox)/launch/online_async_launch.py"/>

    <!-- Navigation -->
    <include file="$(find-pkg-share ecte477)/launch/navigation_launch.py">
        <arg name="params_file" value="$(find-pkg-share ecte477)/params/nav2_params.yaml"/>
    </include>

    <!-- Exploration -->
    <node name="maze_explorer3" pkg="ecte477_starter_python" exec="maze_explorer3" output="screen"/>

    <!-- My Node -->
    <node name="my_node" pkg="demonstration1" exec="my_node" output="screen"/>

    <!-- RViz (don't change) -->
    <node name="rviz2" pkg="rviz2" exec="rviz2" args="-d $(find-pkg-share demonstration1)/config/my_layout.rviz"/>

</launch>
